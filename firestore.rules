rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 📊 Admin Access (Questions & Responses)
    match /questions/{questionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /responses/{responseId} {
      // Customers can read/write to submit rewards
      // Admin (authenticated) has full access
      allow read: if true;
      allow write: if request.resource.data.order_id != null || request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // 🔍 Debug Logs
    match /webhook_logs/{logId} {
      allow read: if request.auth != null;
      allow write: if false; // Only from Functions
    }
  }
}
