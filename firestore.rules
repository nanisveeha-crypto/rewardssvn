rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for Q&A Responses
    match /responses/{responseId} {
      // Allow Read for everyone to check for duplicates
      allow read: if true;

      // Allow Write (Create or Update) for everyone
      // We rely on the unique OrderID match to keep data secure
      allow write: if request.resource.data.order_id != null;
    }

    // Rules for Questions (if stored in DB)
    match /questions/{questionId} {
      allow read: if true;
      allow write: if false; // Admin only (manual or via functions)
    }
  }
}
