rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for Q&A Responses
    match /responses/{responseId} {
      // Allow creation if the document doesn't exist
      // and it contains required fields: order_id and email
      allow create: if !exists(/databases/$(database)/documents/responses/$(responseId))
                    && request.resource.data.order_id != null
                    && request.resource.data.email != null;
      
      // Prevent updates/deletes from the frontend for security
      allow update, delete: if false;
      
      // Allow admin to read responses
      allow read: if request.auth != null; 
    }

    // Rules for Questions (if stored in DB)
    match /questions/{questionId} {
      allow read: if true;
      allow write: if false; // Admin only (manual or via functions)
    }
  }
}
